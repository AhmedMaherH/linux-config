xterm.termName: xterm-256color
xterm.vt100.background: #000000
xterm.vt100.foreground: #dddddd
xterm.vt100.locale: false
xterm.vt100.utf8: true
xterm.vt100.faceName: Noto Sans Regular:antialias=true
xterm.vt100.faceSize: 10.0
xterm.*.saveLines: 4096
xterm.vt100.geometry: 85x25
xterm.*.Translations: #override \
      Shift Ctrl<Key>V: insert-selection(CLIPBOARD) \n\
      Shift Ctrl<Key>V: insert-selection(PRIMARY) \n\
      Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
      Ctrl Shift <Key>C: copy-selection(PRIMARY)
